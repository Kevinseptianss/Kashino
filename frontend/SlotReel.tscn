[gd_scene load_steps=2 format=3]

[sub_resource type="GDScript" id="GDScript_reel"]
script/source = "extends Node2D

signal reel_stopped(results)

@onready var container = $Icons

var icons = []
var spinning = false
var speed = 0.0
var target_speed = 2000.0
var icon_scene = preload(\"res://SlotIcon.tscn\")
var icon_height = 200 # Roughly scale * 512

func _ready():
	# Initialize with 5 icons (3 visible + 2 for buffer)
	for i in range(5):
		var icon = icon_scene.instantiate()
		icon.position.y = i * icon_height
		icon.set_icon(randi() % 6)
		container.add_child(icon)
		icons.append(icon)

func spin():
	spinning = true
	speed = target_speed

func stop():
	spinning = false
	# Snap to grid
	for i in range(icons.size()):
		icons[i].position.y = i * icon_height
	
	var results = []
	for i in range(1, 4): # The 3 visible ones
		results.append(icons[i].type) # Need to add type to SlotIcon script
	reel_stopped.emit(results)

func _process(delta):
	if spinning or speed > 0:
		for icon in icons:
			icon.position.y += speed * delta
			if icon.position.y > icon_height * 4:
				icon.position.y -= icon_height * 5
				icon.set_icon(randi() % 6)
		
		if not spinning:
			speed = lerp(speed, 0.0, delta * 5.0)
			if speed < 100:
				speed = 0
				stop()
"

[node name="SlotReel" type="Node2D"]
script = SubResource("GDScript_reel")

[node name="Icons" type="Node2D" parent="."]
