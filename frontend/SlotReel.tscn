[gd_scene load_steps=2 format=3]

[sub_resource type="GDScript" id="GDScript_reel"]
script/source = "extends Node2D

signal reel_stopped(results)

@onready var container = $Icons

var icons = []
var spinning = false
var speed = 0.0
var target_speed = 3000.0
var icon_scene = preload(\"res://SlotIcon.tscn\")
var icon_height = 120
var target_icons = [] # If set, reel will force these results

func _ready():
	for i in range(10):
		var icon = icon_scene.instantiate()
		icon.position.y = (i - 4) * icon_height
		icon.set_icon(randi() % 6)
		container.add_child(icon)
		icons.append(icon)

func spin():
	spinning = true
	target_icons.clear()
	speed = target_speed
	for icon in icons:
		icon.set_winning(false)

func stop_with_target(targets: Array):
	target_icons = targets
	spinning = false

func stop():
	spinning = false

func _get_icon_at_y(target_y: float):
	var closest = null
	var min_dist = 9999.0
	for icon in icons:
		var dist = abs(icon.position.y - target_y)
		if dist < min_dist:
			min_dist = dist
			closest = icon
	return closest

func get_visible_icon_objects():
	var visible = []
	for y in [-240, -120, 0, 120, 240]:
		visible.append(_get_icon_at_y(y))
	return visible

func _kick_tween():
	speed = 0
	
	# Force targeting if available
	# Row 0 (-240) to Row 4 (240)
	if target_icons.size() == 5:
		for i in range(5):
			var target_y = -240 + (i * 120)
			var icon = _get_icon_at_y(target_y)
			if icon:
				icon.set_icon(target_icons[i])
	
	for icon in icons:
		icon.set_blur(0.0)
		icon.position.y = round(icon.position.y / icon_height) * icon_height
	
	var tween = create_tween()
	tween.set_trans(Tween.TRANS_ELASTIC)
	tween.set_ease(Tween.EASE_OUT)
	tween.tween_property(container, \"position:y\", 20.0, 0.5).as_relative()
	tween.tween_property(container, \"position:y\", -20.0, 0.3).as_relative()
	
	tween.finished.connect(_on_tween_finished)

func _on_tween_finished():
	var results = []
	for y in [-240, -120, 0, 120, 240]:
		var icon = _get_icon_at_y(y)
		results.append(icon.type)
	reel_stopped.emit(results)

func _process(delta):
	if spinning or speed > 200:
		var blur = clamp(speed / 10000.0, 0.0, 0.05)
		for icon in icons:
			icon.position.y += speed * delta
			icon.set_blur(blur)
			
			if icon.position.y > icon_height * 5:
				icon.position.y -= icon_height * 10
				icon.set_icon(randi() % 6)
		
		if not spinning:
			speed = lerp(speed, 0.0, delta * 4.0)
			if speed <= 200:
				_kick_tween()
"

[node name="SlotReel" type="Node2D"]
script = SubResource("GDScript_reel")

[node name="Icons" type="Node2D" parent="."]
