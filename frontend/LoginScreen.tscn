[sub_resource type="Shader" id="Shader_distortion"]
code = "shader_type canvas_item;

uniform float frequency = 10.0;
uniform float amplitude = 0.05;
uniform float speed = 2.0;

void fragment() {
	vec2 uv = UV;
	uv.x += sin(uv.y * frequency + TIME * speed) * amplitude;
	uv.y += cos(uv.x * frequency + TIME * speed) * amplitude;
	COLOR = texture(TEXTURE, uv);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_captcha"]
shader = SubResource("Shader_distortion")
shader_parameter/frequency = 15.0
shader_parameter/amplitude = 0.03
shader_parameter/speed = 3.0

[sub_resource type="GDScript" id="GDScript_login"]
script/source = "extends Control

signal auth_complete

@onready var username_input = %Username
@onready var email_input = %Email
@onready var password_input = %Password
@onready var submit_btn = %SubmitBtn
@onready var switch_btn = %SwitchModeBtn
@onready var error_label = %ErrorLabel

# CAPTCHA nodes
@onready var captcha_container = %CaptchaContainer
@onready var captcha_label = %CaptchaLabel
@onready var captcha_input = %CaptchaInput

var is_login_mode = true
var current_captcha = \"\"

func _ready():
	_update_ui()
	
	if has_node(\"/root/AuthService\"):
		var auth = get_node(\"/root/AuthService\")
		auth.login_success.connect(_on_auth_success)
		auth.login_failed.connect(_on_auth_failed)
		auth.signup_success.connect(_on_auth_success)
		auth.signup_failed.connect(_on_auth_failed)
	else:
		error_label.text = \"ERROR: AuthService not found!\"
		submit_btn.disabled = true

func _generate_captcha():
	var chars = \"ABCDEFGHJKLMNPQRSTUVWXYZ23456789\"
	current_captcha = \"\"
	for i in range(5):
		current_captcha += chars[randi() % chars.length()]
	captcha_label.text = current_captcha

func _update_ui():
	if is_login_mode:
		$VBox/Title.text = \"Welcome Back\"
		email_input.hide()
		captcha_container.hide()
		submit_btn.text = \"Login\"
		switch_btn.text = \"Don't have an account? Sign Up\"
	else:
		$VBox/Title.text = \"Join Kashino\"
		email_input.show()
		captcha_container.show()
		_generate_captcha()
		submit_btn.text = \"Create Account\"
		switch_btn.text = \"Already have an account? Login\"
	error_label.text = \"\"

func _on_switch_mode_pressed():
	is_login_mode = !is_login_mode
	_update_ui()

func _on_submit_pressed():
	if not is_login_mode:
		if captcha_input.text.to_upper() != current_captcha:
			error_label.text = \"Invalid CAPTCHA code!\"
			_generate_captcha()
			captcha_input.text = \"\"
			return

	error_label.text = \"Authenticating...\"
	var auth = get_node(\"/root/AuthService\")
	if is_login_mode:
		auth.login(username_input.text, password_input.text)
	else:
		# Sending both input and expected answer for backend validation
		auth.signup(username_input.text, email_input.text, password_input.text, captcha_input.text.to_upper(), current_captcha)

func _on_auth_success(_user_data):
	auth_complete.emit()
	queue_free()

func _on_auth_failed(msg):
	error_label.text = msg
	if not is_login_mode:
		_generate_captcha()
		captcha_input.text = \"\"
"

