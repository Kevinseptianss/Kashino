[sub_resource type="GDScript" id="GDScript_game"]
script/source = "extends Control

@onready var reels_container = $VBox/Center/Reels
@onready var spin_btn = $VBox/Controls/SpinBtn
@onready var result_label = $VBox/Controls/ResultLabel

var reels = []
var reels_finished = 0
var game_results = []

func _ready():
	for i in range(5):
		var reel = preload(\"res://SlotReel.tscn\").instantiate()
		reel.position.x = i * 140 # spacing
		reels_container.add_child(reel)
		reels.append(reel)
		reel.reel_stopped.connect(_on_reel_stopped)

func _on_spin_pressed():
	if reels_finished < reels.size() and reels_finished > 0: return
	
	reels_finished = 0
	game_results.clear()
	result_label.text = \"\"
	spin_btn.disabled = true
	
	for i in range(reels.size()):
		var reel = reels[i]
		# staggered start
		get_tree().create_timer(i * 0.1).timeout.connect(reel.spin)
		# staggered stop
		get_tree().create_timer(2.0 + i * 0.3).timeout.connect(reel.stop)

func _on_reel_stopped(results):
	reels_finished += 1
	game_results.append(results)
	
	if reels_finished == reels.size():
		spin_btn.disabled = false
		_check_wins()

func _check_wins():
	# Simple check: 3 or more of same icon in the middle row
	var middle_row = []
	for i in range(5):
		middle_row.append(game_results[i][1]) # index 1 is middle
	
	# Transpose game_results if needed, but for middle row it's simple
	var count = 1
	var last_icon = middle_row[0]
	var max_count = 1
	
	# Very basic win logic for demo
	var matches = 1
	for i in range(1, 5):
		if middle_row[i] == last_icon:
			matches += 1
		else:
			break
	
	if matches >= 3:
		result_label.text = \"WIN! %d MATCHES\" % matches
		result_label.add_theme_color_override(\"font_color\", Color.GREEN)
	else:
		result_label.text = \"TRY AGAIN\"
		result_label.add_theme_color_override(\"font_color\", Color.GRAY)

func _on_back_pressed():
	queue_free()
"

