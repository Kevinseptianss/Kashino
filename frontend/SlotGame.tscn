[sub_resource type="GDScript" id="GDScript_game"]
script/source = "extends Control

@onready var reels_container = %Reels
@onready var spin_btn = %SpinBtn
@onready var result_label = %ResultLabel
@onready var balance_label = %BalanceLabel
@onready var coin_particles = %CoinParticles
@onready var camera = %ShakeCamera

var reels = []
var reels_finished = 0
var game_results = []
var shaking = 0.0
var auth = null

var current_bet = 100
var num_lines = 1

func _ready():
	if has_node(\"/root/AuthService\"):
		auth = get_node(\"/root/AuthService\")
		update_balance_display(auth.current_balance)
		auth.balance_updated.connect(update_balance_display)
	
	_update_bet_ui()
	%BetMinusBtn.pressed.connect(_on_bet_minus_pressed)
	%BetPlusBtn.pressed.connect(_on_bet_plus_pressed)
	%LinesSpinBox.value_changed.connect(_on_lines_changed)
	
	for i in range(5):
		var reel = preload(\"res://SlotReel.tscn\").instantiate()
		reel.position.x = i * 130
		reels_container.add_child(reel)
		reels.append(reel)
		reel.reel_stopped.connect(_on_reel_stopped)

func update_balance_display(amount):
	balance_label.text = \"BALANCE: C \" + str(int(amount))

func _on_spin_pressed():
	if reels_finished < reels.size() and reels_finished > 0: return
	
	if auth and auth.current_balance < (current_bet * num_lines):
		result_label.text = \"NOT ENOUGH BALANCE\"
		return
	
	if auth:
		auth.update_balance(-(current_bet * num_lines), \"slot_spin\")
	
	reels_finished = 0
	game_results.clear()
	result_label.text = \"\"
	spin_btn.disabled = true
	
	for i in range(reels.size()):
		var reel = reels[i]
		get_tree().create_timer(i * 0.15).timeout.connect(reel.spin)
		get_tree().create_timer(2.0 + i * 0.4).timeout.connect(reel.stop)

func _on_reel_stopped(results):
	reels_finished += 1
	game_results.append(results)
	shaking = 5.0
	
	if reels_finished == reels.size():
		spin_btn.disabled = false
		_check_wins()

func _check_wins():
	var total_win = 0
	var win_details = []
	
	# 5x3 Result Grid
	var grid = [] # rows[3] -> cols[5]
	for row in range(3):
		var row_icons = []
		for col in range(5):
			row_icons.append(game_results[col][row])
		grid.append(row_icons)
	
	# Define Lines (0-middle, 1-top, 2-bottom, 3-diag1, 4-diag2)
	var lines = [
		[1,1,1,1,1], # Middle
		[0,0,0,0,0], # Top
		[2,2,2,2,2], # Bottom
		[0,1,2,1,0], # V-shape
		[2,1,0,1,2], # Inverted V
		[0,0,1,2,2], # Step Down
		[2,2,1,0,0], # Step Up
		[1,0,0,0,1], # Top arc
		[1,2,2,2,1]  # Bottom arc
	]
	
	var logged_grid = []
	for c in range(5):
		logged_grid.append(game_results[c])

	for i in range(min(num_lines, lines.size())):
		var line = lines[i]
		var line_icons = []
		for col in range(5):
			line_icons.append(grid[line[col]][col])
		
		var last_icon = line_icons[0]
		var matches = 1
		for j in range(1, 5):
			if line_icons[j] == last_icon:
				matches += 1
			else:
				break
		
		if matches >= 3:
			var multiplier = 5
			if matches == 4: multiplier = 25
			elif matches == 5: multiplier = 150
			
			var win = current_bet * multiplier
			total_win += win
			win_details.append(\"LINE %d: %d MATCHES (C %d)\" % [i+1, matches, win])
	
	if total_win > 0:
		result_label.text = \"WIN: C %d!\" % total_win
		if win_details.size() > 1:
			result_label.text += \" (%d LINES)\" % win_details.size()
			
		result_label.modulate = Color(1, 0.9, 0)
		shaking = 20.0
		coin_particles.emitting = true
		if auth:
			auth.update_balance(total_win, \"slot_win\")
	else:
		result_label.text = \"SPIN AGAIN\"
		result_label.modulate = Color(1, 1, 1, 0.6)
	
	# Send Log to Database
	if auth:
		auth._send_ws_message(\"slot_log\", {
			\"bet\": current_bet,
			\"lines\": num_lines,
			\"result\": logged_grid,
			\"win_amount\": total_win
		})

func _on_bet_minus_pressed():
	if current_bet > 1:
		current_bet = max(1, current_bet - 10)
		_update_bet_ui()

func _on_bet_plus_pressed():
	current_bet += 10
	_update_bet_ui()

func _on_lines_changed(val):
	num_lines = int(val)
	_update_bet_ui()

func _update_bet_ui():
	%BetInfo.text = str(current_bet)

func _process(delta):
	if shaking > 0:
		camera.offset = Vector2(randf_range(-shaking, shaking), randf_range(-shaking, shaking))
		shaking = lerp(shaking, 0.0, delta * 8.0)
	else:
		camera.offset = Vector2.ZERO

func _on_back_pressed():
	queue_free()
"

