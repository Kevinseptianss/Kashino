[sub_resource type="GDScript" id="GDScript_poker_table"]
script/source = "extends Control

var room_id = \"\"
var auth = null
var current_room = null
var _last_room = null
var _turn_tween: Tween = null

# Card animation state
var _animate_next_cards: bool = false
var _card_animation_index: int = 0

@onready var community_container = %CommunityCards
@onready var pot_label = %PotLabel
@onready var info_label = %InfoLabel
@onready var seats = [
	%Seat0, %Seat1, %Seat2, %Seat3, %Seat4
]
@onready var controls = %Controls
@onready var fold_btn = %FoldBtn
@onready var check_btn = %CheckBtn
@onready var call_btn = %CallBtn
@onready var raise_btn = %RaiseBtn
@onready var winner_label = %WinnerLabel
@onready var standup_btn = %StandUpBtn
@onready var bet_slider = %BetSlider
@onready var bet_label = %BetValueLabel
@onready var fireworks = %Fireworks
@onready var turn_highlight = %TurnHighlight
@onready var dealer_button = %DealerButton

func _ready():
	turn_highlight.hide()
	if has_node(\"/root/AuthService\"):
		auth = get_node(\"/root/AuthService\")
		auth.player_sat.connect(_on_player_sat)
		auth.room_joined.connect(_on_room_update)
		auth.room_update.connect(_on_room_update)
		
		# Join the room
		auth._send_ws_message(\"join_room\", {\"room_id\": room_id})
	
	fold_btn.pressed.connect(func(): _send_action(\"fold\"))
	check_btn.pressed.connect(func(): _send_action(\"check\"))
	call_btn.pressed.connect(func():
		var to_call = _get_call_amount()
		_send_action(\"call\", to_call)
	)
	raise_btn.pressed.connect(func():
		_send_action(\"raise\", int(bet_slider.value))
	)
	standup_btn.pressed.connect(_on_standup_pressed)
	bet_slider.value_changed.connect(_on_bet_slider_changed)

func _on_bet_slider_changed(val):
	bet_label.text = \"RAISE TO: C \" + str(int(val))
	raise_btn.text = \"RAISE TO\\n(C \" + str(int(val)) + \")\"

func _on_room_update(room_data):
	if room_data.get(\"id\") != room_id: return
	current_room = room_data
	_process_animations(room_data)
	_refresh_ui()
	_last_room = room_data.duplicate(true)

func _on_player_sat(room_data):
	if room_data.get(\"id\") != room_id: return
	current_room = room_data
	_refresh_ui()
	_last_room = room_data.duplicate(true)

func _process_animations(new_room):
	if not _last_room: 
		# First time joining – if game already started, animate cards in
		var new_state = new_room.get(\"game_state\", {})
		var new_round = new_state.get(\"round\", \"\")
		if new_round in [\"pre-flop\", \"flop\", \"turn\", \"river\"]:
			_animate_next_cards = true
		return
	
	var old_state = _last_room.get(\"game_state\", {})
	var new_state = new_room.get(\"game_state\", {})
	
	# Detect round change for card dealing animation
	var old_round = old_state.get(\"round\", \"\")
	var new_round = new_state.get(\"round\", \"\")
	if old_round != new_round and new_round in [\"pre-flop\", \"flop\", \"turn\", \"river\"]:
		_animate_next_cards = true
	
	# Detect Actions and Play Popups
	for i in range(new_state.get(\"players\", []).size()):
		var p_new = new_state[\"players\"][i]
		var p_old = null
		for op in old_state.get(\"players\", []):
			if op[\"id\"] == p_new[\"id\"]:
				p_old = op
				break
		
		if p_old:
			var seat_idx = p_new[\"position\"]
			# Detect Fold
			if p_new[\"is_folded\"] and not p_old[\"is_folded\"]:
				_spawn_popup(seat_idx, \"FOLD\", Color.RED)
			# Detect Check/Call/Raise (LastBet increased)
			elif p_new[\"last_bet\"] > p_old[\"last_bet\"]:
				var diff = p_new[\"last_bet\"] - p_old[\"last_bet\"]
				if p_old[\"last_bet\"] == 0 and new_state[\"round\"] != \"pre-flop\":
					_spawn_popup(seat_idx, \"BET \" + str(int(p_new[\"last_bet\"])), Color.GREEN)
				else:
					_spawn_popup(seat_idx, \"RAISE \" + str(int(p_new[\"last_bet\"])), Color.ORANGE)
				_animate_chips(seat_idx)

func _spawn_popup(seat_idx, text, color):
	var label = Label.new()
	label.text = text
	label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	label.add_theme_color_override(\"font_color\", color)
	label.add_theme_font_size_override(\"font_size\", 24)
	label.add_theme_constant_override(\"outline_size\", 4)
	add_child(label)
	
	var start_pos = seats[seat_idx].global_position + Vector2(60, 0)
	label.global_position = start_pos
	
	var tween = create_tween()
	tween.set_parallel(true)
	tween.tween_property(label, \"global_position\", start_pos + Vector2(0, -100), 1.0)
	tween.tween_property(label, \"modulate:a\", 0.0, 1.0).set_delay(0.5)
	tween.chain().finished.connect(label.queue_free)

func _animate_chips(seat_idx):
	var chip = ColorRect.new()
	chip.custom_minimum_size = Vector2(20, 20)
	chip.color = Color.GOLD
	add_child(chip)
	chip.global_position = seats[seat_idx].global_position + Vector2(60, 50)
	
	var tween = create_tween()
	tween.tween_property(chip, \"global_position\", pot_label.global_position + Vector2(100, 15), 0.6).set_trans(Tween.TRANS_QUAD).set_ease(Tween.EASE_OUT)
	tween.chain().finished.connect(chip.queue_free)

func _get_call_amount() -> int:
	if not current_room or not auth or not auth.current_user: return 0
	var my_id = auth.current_user[\"id\"]
	var max_bet = 0
	var my_bet = 0
	for p in current_room[\"game_state\"][\"players\"]:
		if p[\"last_bet\"] > max_bet:
			max_bet = p[\"last_bet\"]
		if p[\"id\"] == my_id:
			my_bet = p[\"last_bet\"]
	return max_bet - my_bet

func _refresh_ui():
	if not current_room: return
	
	# Reset card animation index if we're about to animate new cards
	if _animate_next_cards:
		_card_animation_index = 0
	
	var id = auth.current_user[\"id\"] if auth and auth.current_user else \"\"
	var is_seated = false
	var my_player = null
	for p in current_room[\"game_state\"][\"players\"]:
		if p[\"id\"] == id:
			is_seated = true
			my_player = p
			break
	
	winner_label.hide()
	pot_label.text = \"POT: C \" + str(int(current_room[\"game_state\"][\"pot\"]))
	info_label.text = current_room[\"name\"] + \" - \" + current_room[\"game_state\"][\"round\"].to_upper() + \" (\" + str(int(current_room[\"small_blind\"])) + \"/\" + str(int(current_room[\"big_blind\"])) + \")\"
	
	var winners = current_room[\"game_state\"].get(\"last_winners\", [])
	if current_room[\"game_state\"][\"round\"] == \"waiting\" and winners.size() > 0:
		var names = []
		var hand = \"\"
		for w in winners:
			names.append(w[\"username\"])
			hand = w[\"hand_description\"]
			if winners.find(w) == 0:
				for i in range(5):
					var p = _get_player_at_seat(i)
					if p and p[\"id\"] == w[\"user_id\"]:
						fireworks.global_position = seats[i].global_position + Vector2(60, 50)
						fireworks.emitting = true
						# Play multiple bursts
						get_tree().create_timer(0.4).timeout.connect(func(): fireworks.restart())
						break
		
		winner_label.text = \", \".join(names) + \" WINS!\\n\" + hand
		winner_label.show()
	elif current_room[\"game_state\"][\"round\"] == \"waiting\" and current_room[\"game_state\"][\"players\"].size() >= 2:
		winner_label.text = \"HAND OVER - DIVIDING POT\"
		winner_label.show()
	else:
		fireworks.emitting = false
	
	standup_btn.visible = is_seated
	
	# Turn Highlight
	var turn_id = current_room[\"game_state\"][\"current_turn\"]
	var found_turn = false
	# 2. Update Seats and Player Cards
	for i in range(5):
		var seat = seats[i]
		var player = _get_player_at_seat(i)
		var card_hbox = seat.get_node(\"Cards\")
		var rank_label = seat.get_node(\"HandRank\")
		
		if player:
			seat.get_node(\"Label\").text = player[\"username\"] + \"\\nC \" + str(int(player[\"balance\"]))
			seat.get_node(\"SitBtn\").hide()
			
			if player[\"id\"] == turn_id and current_room[\"game_state\"][\"round\"] != \"waiting\":
				_update_turn_highlight(i)
				found_turn = true
			
			var bet_badge = seat.get_node(\"BetBadge\")
			var total_bet = int(player.get(\"last_bet\", 0))
			if total_bet > 0:
				bet_badge.get_node(\"Label\").text = \"BET: C \" + str(total_bet)
				bet_badge.show()
			else:
				bet_badge.hide()
			
			var hand_rank = player.get(\"current_hand\", \"\")
			if hand_rank and player[\"in_game\"] and not player[\"is_folded\"]:
				rank_label.text = hand_rank
				rank_label.show()
			else:
				rank_label.hide()
			
			# PLAYER CARDS SEQUENTIAL REVEAL
			var player_cards = player.get(\"cards\", [])
			var is_waiting = current_room[\"game_state\"][\"round\"] == \"waiting\"
			var current_card_count = card_hbox.get_child_count()
			
			if player.get(\"is_folded\", false):
				# Immediately clear cards if folded
				for child in card_hbox.get_children(): child.queue_free()
			elif player[\"in_game\"]:
				var target_count = 2
				if player_cards.size() > 0: target_count = player_cards.size()
				
				if current_card_count < target_count:
					# Deal new cards one by one
					for j in range(current_card_count, target_count):
						var card = preload(\"res://PokerCard.tscn\").instantiate()
						card_hbox.add_child(card)
						if player_cards.size() > j:
							if player[\"id\"] == auth.current_user[\"id\"] or current_room[\"game_state\"][\"round\"] == \"showdown\" or is_waiting:
								card.set_card(player_cards[j][\"suit\"], player_cards[j][\"value\"])
							else:
								card.set_back()
						else:
							card.set_back()
						
						card.modulate.a = 0
						card.scale = Vector2.ZERO
						var tween = create_tween().set_parallel(true)
						tween.tween_property(card, \"modulate:a\", 1.0, 0.2)
						tween.tween_property(card, \"scale\", Vector2.ONE, 0.3).set_trans(Tween.TRANS_BACK).set_ease(Tween.EASE_OUT)
						await get_tree().create_timer(0.2).timeout
				elif current_card_count == target_count and (is_waiting or current_room[\"game_state\"][\"round\"] == \"showdown\"):
					# Reveal existing cards at showdown or end of hand
					for j in range(current_card_count):
						var card = card_hbox.get_child(j)
						if player_cards.size() > j:
							card.set_card(player_cards[j][\"suit\"], player_cards[j][\"value\"])
		else:
			seat.get_node(\"Label\").text = \"Empty\"
			seat.get_node(\"SitBtn\").visible = not is_seated
			seat.get_node(\"BetBadge\").hide()
			rank_label.hide()
			for child in card_hbox.get_children(): child.queue_free()
	
	if not found_turn: turn_highlight.hide()

	# Dealer Button
	var dealer_idx = current_room[\"game_state\"].get(\"dealer_idx\", -1)
	var d_players = current_room[\"game_state\"][\"players\"]
	if dealer_idx >= 0 and dealer_idx < d_players.size():
		var d_player = d_players[dealer_idx]
		var d_seat_idx = d_player[\"position\"]
		dealer_button.show()
		var dealer_target = seats[d_seat_idx].global_position + Vector2(100, 20)
		dealer_button.global_position = dealer_target
	else:
		dealer_button.hide()

	# Community Cards Reveal
	var community = current_room[\"game_state\"].get(\"community\", [])
	var existing_community = community_container.get_child_count()
	
	if current_room[\"game_state\"][\"round\"] == \"waiting\":
		# Clear community cards for next hand
		for child in community_container.get_children(): child.queue_free()
		existing_community = 0
		
	if community.size() > existing_community:
		# Reveal new cards one by one
		for i in range(existing_community, community.size()):
			var card_data = community[i]
			var card = preload(\"res://PokerCard.tscn\").instantiate()
			community_container.add_child(card)
			card.set_card(card_data[\"suit\"], card_data[\"value\"])
			card.modulate.a = 0
			card.scale = Vector2.ZERO
			var tween = create_tween().set_parallel(true)
			tween.tween_property(card, \"modulate:a\", 1.0, 0.3)
			tween.tween_property(card, \"scale\", Vector2.ONE, 0.4).set_trans(Tween.TRANS_BACK).set_ease(Tween.EASE_OUT)
			await get_tree().create_timer(0.4).timeout

	var id_turn = auth.current_user[\"id\"] if auth and auth.current_user else \"\"
	var my_turn = current_room[\"game_state\"][\"current_turn\"] == id_turn
	controls.visible = my_turn
	
	if my_turn and my_player:
		var call_amt = _get_call_amount()
		call_btn.text = \"CALL\\n(C \" + str(call_amt) + \")\"
		check_btn.visible = (call_amt == 0)
		call_btn.visible = (call_amt > 0)
		var bb = int(current_room.get(\"big_blind\", 20))
		var max_bet = 0
		for p in current_room[\"game_state\"][\"players\"]:
			if p[\"last_bet\"] > max_bet: max_bet = p[\"last_bet\"]
		var min_raise = max_bet + bb
		bet_slider.min_value = min_raise
		bet_slider.max_value = my_player[\"balance\"] + my_player[\"last_bet\"]
		bet_slider.step = bb
		bet_slider.value = min_raise
		_on_bet_slider_changed(bet_slider.value)
	
	# Done animating this batch
	_animate_next_cards = false

func _update_turn_highlight(seat_idx):
	if _turn_tween: _turn_tween.kill()
	turn_highlight.show()
	var target_pos = seats[seat_idx].global_position - Vector2(10, 30)
	
	# Move to seat and pulse
	var tween = create_tween()
	tween.tween_property(turn_highlight, \"global_position\", target_pos, 0.3).set_trans(Tween.TRANS_CUBIC)
	_turn_tween = create_tween().set_loops()
	_turn_tween.tween_property(turn_highlight, \"modulate:a\", 0.3, 0.5)
	_turn_tween.tween_property(turn_highlight, \"modulate:a\", 1.0, 0.5)

func _send_action(action_type, amount = 0):
	if auth:
		auth._send_ws_message(\"poker_action\", {
			\"room_id\": room_id,
			\"action\": {
				\"action\": action_type,
				\"amount\": amount
			}
		})

func _get_player_at_seat(pos):
	for p in current_room[\"game_state\"][\"players\"]:
		if p[\"position\"] == pos:
			return p
	return null

func _on_sit_pressed(seat_idx):
	if auth:
		auth._send_ws_message(\"sit\", {\"room_id\": room_id, \"seat\": seat_idx})

func _on_standup_pressed():
	if auth:
		auth._send_ws_message(\"standup\", {\"room_id\": room_id})

func _on_back_pressed():
	queue_free()
"

