[sub_resource type="GDScript" id="GDScript_poker_table"]
script/source = "extends Control

var room_id = \"\"
var auth = null
var current_room = null

@onready var community_container = %CommunityCards
@onready var pot_label = %PotLabel
@onready var info_label = %InfoLabel
@onready var seats = [
	%Seat0, %Seat1, %Seat2, %Seat3, %Seat4
]
@onready var controls = %Controls
@onready var fold_btn = %FoldBtn
@onready var check_btn = %CheckBtn
@onready var call_btn = %CallBtn
@onready var raise_btn = %RaiseBtn
@onready var winner_label = %WinnerLabel
@onready var standup_btn = %StandUpBtn
@onready var bet_slider = %BetSlider
@onready var bet_label = %BetValueLabel
@onready var fireworks = %Fireworks

func _ready():
	if has_node(\"/root/AuthService\"):
		auth = get_node(\"/root/AuthService\")
		auth.player_sat.connect(_on_player_sat)
		auth.room_joined.connect(_on_room_update)
		auth.room_update.connect(_on_room_update)
		
		# Join the room
		auth._send_ws_message(\"join_room\", {\"room_id\": room_id})
	
	fold_btn.pressed.connect(func(): _send_action(\"fold\"))
	check_btn.pressed.connect(func(): _send_action(\"check\"))
	call_btn.pressed.connect(func():
		var to_call = _get_call_amount()
		_send_action(\"call\", to_call)
	)
	raise_btn.pressed.connect(func():
		_send_action(\"raise\", int(bet_slider.value))
	)
	standup_btn.pressed.connect(_on_standup_pressed)
	bet_slider.value_changed.connect(_on_bet_slider_changed)

func _on_bet_slider_changed(val):
	bet_label.text = \"RAISE TO: C \" + str(int(val))
	raise_btn.text = \"RAISE TO\\n(C \" + str(int(val)) + \")\"

func _on_room_update(room_data):
	if room_data.get(\"id\") != room_id: return
	print(\"PokerTable: Room update received for \", room_id)
	current_room = room_data
	_refresh_ui()

func _on_player_sat(room_data):
	if room_data.get(\"id\") != room_id: return
	print(\"PokerTable: Player sat in \", room_id)
	current_room = room_data
	_refresh_ui()

func _get_call_amount() -> int:
	if not current_room or not auth or not auth.current_user: return 0
	var my_id = auth.current_user[\"id\"]
	var max_bet = 0
	var my_bet = 0
	for p in current_room[\"game_state\"][\"players\"]:
		if p[\"last_bet\"] > max_bet:
			max_bet = p[\"last_bet\"]
		if p[\"id\"] == my_id:
			my_bet = p[\"last_bet\"]
	return max_bet - my_bet

func _refresh_ui():
	if not current_room: return
	
	var id = auth.current_user[\"id\"] if auth and auth.current_user else \"\"
	var is_seated = false
	var my_player = null
	for p in current_room[\"game_state\"][\"players\"]:
		if p[\"id\"] == id:
			is_seated = true
			my_player = p
			break
	
	print(\"PokerTable: Refreshing UI. is_seated: \", is_seated, \" Players: \", current_room[\"game_state\"][\"players\"].size())
	winner_label.hide()
	pot_label.text = \"POT: C \" + str(int(current_room[\"game_state\"][\"pot\"]))
	info_label.text = current_room[\"name\"] + \" - \" + current_room[\"game_state\"][\"round\"].to_upper() + \" (\" + str(int(current_room[\"small_blind\"])) + \"/\" + str(int(current_room[\"big_blind\"])) + \")\"
	
	var winners = current_room[\"game_state\"].get(\"last_winners\", [])
	if current_room[\"game_state\"][\"round\"] == \"waiting\" and winners.size() > 0:
		var names = []
		var hand = \"\"
		for w in winners:
			names.append(w[\"username\"])
			hand = w[\"hand_description\"]
			# Fireworks for the first winner (usually just one)
			if winners.find(w) == 0:
				for i in range(5):
					var p = _get_player_at_seat(i)
					if p and p[\"id\"] == w[\"user_id\"]:
						fireworks.global_position = seats[i].global_position + Vector2(60, 50)
						fireworks.emitting = true
						break
		
		winner_label.text = \", \".join(names) + \" WINS!\\n\" + hand
		winner_label.show()
	elif current_room[\"game_state\"][\"round\"] == \"waiting\" and current_room[\"game_state\"][\"players\"].size() >= 2:
		winner_label.text = \"HAND OVER - DIVIDING POT\"
		winner_label.show()
	else:
		_fireworks.emitting = false
	
	standup_btn.visible = is_seated
	
	for i in range(5):
		var seat = seats[i]
		var player = _get_player_at_seat(i)
		var card_hbox = seat.get_node(\"Cards\")
		var rank_label = seat.get_node(\"HandRank\")
		# Clear old cards
		for child in card_hbox.get_children(): child.queue_free()
		
		if player:
			seat.get_node(\"Label\").text = player[\"username\"] + \"\\nC \" + str(int(player[\"balance\"]))
			seat.get_node(\"SitBtn\").hide()
			
			# Show total bet
			var bet_badge = seat.get_node(\"BetBadge\")
			var total_bet = int(player.get(\"last_bet\", 0))
			if total_bet > 0:
				bet_badge.get_node(\"Label\").text = \"BET: C \" + str(total_bet)
				bet_badge.show()
			else:
				bet_badge.hide()
			
			# Show hand ranking if available
			var hand_rank = player.get(\"current_hand\", \"\")
			if hand_rank and player[\"in_game\"] and not player[\"is_folded\"]:
				rank_label.text = hand_rank
				rank_label.show()
			else:
				rank_label.hide()
			
			# Show cards
			var player_cards = player.get(\"cards\", [])
			var is_playing = current_room[\"game_state\"][\"round\"] != \"waiting\"
			
			if player_cards and player_cards.size() > 0 and is_playing:
				for card_data in player_cards:
					var card = preload(\"res://PokerCard.tscn\").instantiate()
					card_hbox.add_child(card)
					# Only show front if it's the current user or showdown
					if player[\"id\"] == auth.current_user[\"id\"] or current_room[\"game_state\"][\"round\"] == \"showdown\":
						card.set_card(card_data[\"suit\"], card_data[\"value\"])
					else:
						card.set_back()
			elif player[\"in_game\"] and not player[\"is_folded\"] and is_playing:
				# Show card placeholders/backs for other players if in game and round started
				for j in range(2):
					var card = preload(\"res://PokerCard.tscn\").instantiate()
					card_hbox.add_child(card)
					card.set_back()
		else:
			seat.get_node(\"Label\").text = \"Empty\"
			seat.get_node(\"SitBtn\").visible = not is_seated
			seat.get_node(\"BetBadge\").hide()
			rank_label.hide()

	# Update Community Cards
	for child in community_container.get_children(): child.queue_free()
	var community = current_room[\"game_state\"].get(\"community\", [])
	if community:
		for card_data in community:
			var card = preload(\"res://PokerCard.tscn\").instantiate()
			community_container.add_child(card)
			card.set_card(card_data[\"suit\"], card_data[\"value\"])

	# Toggle controls based on turn
	var id_turn = auth.current_user[\"id\"] if auth and auth.current_user else \"\"
	var my_turn = current_room[\"game_state\"][\"current_turn\"] == id_turn
	controls.visible = my_turn
	
	if my_turn and my_player:
		var call_amt = _get_call_amount()
		call_btn.text = \"CALL\\n(C \" + str(call_amt) + \")\"
		check_btn.visible = (call_amt == 0)
		call_btn.visible = (call_amt > 0)
		
		# Setup slider
		var bb = int(current_room.get(\"big_blind\", 20))
		var max_bet = 0
		for p in current_room[\"game_state\"][\"players\"]:
			if p[\"last_bet\"] > max_bet: max_bet = p[\"last_bet\"]
			
		var min_raise = max_bet + bb
		
		bet_slider.min_value = min_raise
		bet_slider.max_value = my_player[\"balance\"] + my_player[\"last_bet\"] # Total wealth can be bet
		bet_slider.step = bb # Step by BB or at least something consistent
		bet_slider.value = min_raise
		
		_on_bet_slider_changed(bet_slider.value)

func _send_action(action_type, amount = 0):
	if auth:
		auth._send_ws_message(\"poker_action\", {
			\"room_id\": room_id,
			\"action\": {
				\"action\": action_type,
				\"amount\": amount
			}
		})

func _get_player_at_seat(pos):
	for p in current_room[\"game_state\"][\"players\"]:
		if p[\"position\"] == pos:
			return p
	return null

func _on_sit_pressed(seat_idx):
	if auth:
		auth._send_ws_message(\"sit\", {\"room_id\": room_id, \"seat\": seat_idx})

func _on_standup_pressed():
	if auth:
		auth._send_ws_message(\"standup\", {\"room_id\": room_id})

func _on_back_pressed():
	queue_free()
"

