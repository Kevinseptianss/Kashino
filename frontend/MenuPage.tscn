[sub_resource type="GDScript" id="GDScript_menu"]
script/source = "extends Control

func _on_back_pressed():
	queue_free()

func _on_logout_pressed():
	if has_node(\"/root/AuthService\"):
		var auth = get_node(\"/root/AuthService\")
		auth.clear_auth()
		var main = get_tree().root.get_node(\"Main\")
		if main:
			main._on_logout()
		queue_free()

func _on_change_username_pressed():
	print(\"Change Username pressed - Backend support pending\")

func _on_change_password_pressed():
	print(\"Change Password pressed - Backend support pending\")

func _on_change_email_pressed():
	print(\"Change Email pressed - Backend support pending\")

func _on_change_avatar_pressed():
	if not has_node(\"/root/AuthService\"): return
	var auth = get_node(\"/root/AuthService\")
	if not auth.current_user: return
	
	# Open file dialog for profile picture selection
	var dialog = FileDialog.new()
	dialog.file_mode = FileDialog.FILE_MODE_OPEN_FILE
	dialog.access = FileDialog.ACCESS_FILESYSTEM
	dialog.filters = PackedStringArray([\"*.png, *.jpg, *.jpeg ; Image Files\"])
	dialog.size = Vector2i(600, 400)
	dialog.title = \"Select Profile Picture\"
	add_child(dialog)
	dialog.file_selected.connect(_on_avatar_file_selected)
	dialog.popup_centered()

func _on_avatar_file_selected(path):
	var image = Image.load_from_file(path)
	if image == null:
		print(\"Failed to load image: \", path)
		return
	
	# Resize to 128x128
	image.resize(128, 128)
	var png_data = image.save_png_to_buffer()
	var base64 = Marshalls.raw_to_base64(png_data)
	
	if has_node(\"/root/AuthService\"):
		var auth = get_node(\"/root/AuthService\")
		auth.set_profile_picture(base64)
		print(\"Profile picture uploaded\")

func _on_slots_pressed():
	var main = get_tree().root.get_node(\"Main\")
	if main:
		main._on_slot_pressed()
	queue_free()

func _on_poker_pressed():
	var main = get_tree().root.get_node(\"Main\")
	if main:
		main._on_poker_pressed()
	queue_free()
"

