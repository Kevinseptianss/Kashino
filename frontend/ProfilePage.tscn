[sub_resource type="GDScript" id="GDScript_profile"]
script/source = "extends Control

@onready var history_list = $VBox/Scroll/HistoryList
@onready var username_label = $VBox/ScrollWrap/Scroll/Inner/ProfileCard/Margin/VBox/Username
@onready var tier_label = $VBox/ScrollWrap/Scroll/Inner/ProfileCard/Margin/VBox/TierRow/TierLabel
@onready var level_label = $VBox/ScrollWrap/Scroll/Inner/ProfileCard/Margin/VBox/TierRow/LevelLabel
@onready var exp_bar = $VBox/ScrollWrap/Scroll/Inner/ProfileCard/Margin/VBox/ExpBar
@onready var exp_label = $VBox/ScrollWrap/Scroll/Inner/ProfileCard/Margin/VBox/ExpLabel
@onready var balance_label = $VBox/ScrollWrap/Scroll/Inner/BalanceCard/Margin/VBox/Balance
@onready var avatar_ring = $VBox/ScrollWrap/Scroll/Inner/ProfileCard/Margin/VBox/AvatarContainer/AvatarRing
@onready var avatar_initial = $VBox/ScrollWrap/Scroll/Inner/ProfileCard/Margin/VBox/AvatarContainer/AvatarRing/InitialLabel

const TIER_COLORS = {
	\"Wood\": Color(0.55, 0.41, 0.08, 1),
	\"Bronze\": Color(0.8, 0.5, 0.2, 1),
	\"Silver\": Color(0.75, 0.75, 0.75, 1),
	\"Gold\": Color(1, 0.84, 0, 1),
	\"Fire\": Color(1, 0.27, 0, 1),
	\"Diamond\": Color(0, 1, 1, 1)
}

func _ready():
	if has_node(\"/root/AuthService\"):
		var auth = get_node(\"/root/AuthService\")
		if not auth.current_user:
			username_label.text = \"Not Logged In\"
			return
		
		var user = auth.current_user
		username_label.text = user.get(\"username\", \"Guest\")
		
		# Avatar
		var initial = user.get(\"username\", \"?\")[0].to_upper()
		avatar_initial.text = initial
		
		# Tier
		var tier = user.get(\"tier\", \"Wood\")
		var color = TIER_COLORS.get(tier, TIER_COLORS[\"Wood\"])
		avatar_ring.color = color
		tier_label.text = tier.to_upper()
		tier_label.add_theme_color_override(\"font_color\", color)
		
		# Level
		var level = user.get(\"level\", 1)
		level_label.text = \"LV. \" + str(level)
		
		# EXP bar
		var exp_val = user.get(\"exp\", 0)
		var exp_for_current = (level - 1) * 200
		var exp_for_next = level * 200
		var progress = float(exp_val - exp_for_current) / float(exp_for_next - exp_for_current)
		exp_bar.value = clamp(progress * 100, 0, 100)
		exp_label.text = str(exp_val) + \" / \" + str(exp_for_next) + \" EXP\"
		
		_update_balance_display(auth.current_balance)
		
		if not auth.balance_updated.is_connected(_update_balance_display):
			auth.balance_updated.connect(_update_balance_display)
		if not auth.history_received.is_connected(_display_history):
			auth.history_received.connect(_display_history)
		
		auth.get_history()

func _update_balance_display(amount):
	var formatted = \"\"
	var s = str(int(amount))
	var count = 0
	for i in range(s.length() - 1, -1, -1):
		formatted = s[i] + formatted
		count += 1
		if count == 3 and i > 0:
			formatted = \" \" + formatted
			count = 0
	balance_label.text = \"C \" + formatted

func _display_history(history):
	for child in history_list.get_children():
		child.queue_free()
	
	if not history or history.size() == 0:
		var empty = Label.new()
		empty.text = \"No history available\"
		empty.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
		empty.add_theme_color_override(\"font_color\", Color(0.5, 0.45, 0.4, 0.5))
		history_list.add_child(empty)
		return
	
	history.reverse()
	
	for item in history:
		var card = PanelContainer.new()
		var card_style = StyleBoxFlat.new()
		card_style.bg_color = Color(0.1, 0.08, 0.14, 0.6)
		card_style.corner_radius_top_left = 10
		card_style.corner_radius_top_right = 10
		card_style.corner_radius_bottom_right = 10
		card_style.corner_radius_bottom_left = 10
		card_style.content_margin_left = 15
		card_style.content_margin_right = 15
		card_style.content_margin_top = 12
		card_style.content_margin_bottom = 12
		card.add_theme_stylebox_override(\"panel\", card_style)
		history_list.add_child(card)
		
		var hbox = HBoxContainer.new()
		card.add_child(hbox)
		
		var v_info = VBoxContainer.new()
		v_info.size_flags_horizontal = Control.SIZE_EXPAND_FILL
		hbox.add_child(v_info)
		
		var source_label = Label.new()
		var source = item.get(\"source\", \"Unknown\")
		source_label.text = source.to_upper().replace(\"_\", \" \")
		source_label.add_theme_font_size_override(\"font_size\", 14)
		source_label.add_theme_color_override(\"font_color\", Color(0.85, 0.78, 0.6, 0.9))
		v_info.add_child(source_label)
		
		var date_label = Label.new()
		var ts = item.get(\"timestamp\", 0)
		if ts is Dictionary and ts.has(\"$date\"): 
			ts = ts[\"$date\"]
		var formatted_date = _format_timestamp(ts)
		if formatted_date != \"\":
			date_label.text = formatted_date
			date_label.add_theme_font_size_override(\"font_size\", 11)
			date_label.add_theme_color_override(\"font_color\", Color(0.5, 0.45, 0.4, 0.6))
			v_info.add_child(date_label)
		
		var amount_label = Label.new()
		var amount_val = item.get(\"amount\", 0)
		var amount_str = str(int(amount_val))
		if amount_val > 0: amount_str = \"+\" + amount_str
		amount_label.text = amount_str
		amount_label.add_theme_font_size_override(\"font_size\", 18)
		if amount_val < 0:
			amount_label.add_theme_color_override(\"font_color\", Color(1, 0.35, 0.35, 0.9))
		else:
			amount_label.add_theme_color_override(\"font_color\", Color(0.35, 1, 0.35, 0.9))
		hbox.add_child(amount_label)

func _format_timestamp(ts):
	if ts == null or str(ts) == \"\" or str(ts) == \"0\": 
		return \"\"
	
	var unix_time = 0.0
	var ts_str = str(ts)
	
	if ts is String:
		if ts_str.is_valid_float() or ts_str.is_valid_int():
			unix_time = float(ts_str) / 1000.0
		else:
			unix_time = Time.get_unix_time_from_datetime_string(ts_str)
	elif ts is float or ts is int:
		unix_time = float(ts) / 1000.0
	
	if unix_time <= 0: return \"\"
	
	var dict = Time.get_datetime_dict_from_unix_time(int(unix_time))
	return \"%04d-%02d-%02d %02d:%02d\" % [dict.year, dict.month, dict.day, dict.hour, dict.minute]

func _on_back_pressed():
	queue_free()
"

