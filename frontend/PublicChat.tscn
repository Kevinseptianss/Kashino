[sub_resource type="GDScript" id="GDScript_public_chat"]
script/source = "extends Control

var auth = null
var _messages = []

@onready var chat_log = %ChatLog
@onready var chat_input = %ChatInput
@onready var send_btn = %SendBtn
@onready var back_btn = %BackBtn
@onready var login_notice = %LoginNotice
@onready var input_row = %InputRow

func _ready():
	if has_node(\"/root/AuthService\"):
		auth = get_node(\"/root/AuthService\")
		auth.public_chat_message_received.connect(_on_message)
		auth.public_chat_history_received.connect(_on_history)
		auth.request_public_chat_history()
	
	var is_logged = auth and auth.current_user
	input_row.visible = is_logged
	login_notice.visible = not is_logged
	
	back_btn.pressed.connect(_on_back_pressed)
	send_btn.pressed.connect(_on_send_pressed)
	chat_input.text_submitted.connect(_on_input_submitted)

func _on_back_pressed():
	queue_free()

func _on_send_pressed():
	var msg = chat_input.text.strip_edges()
	if msg == \"\" or not auth or not auth.current_user: return
	auth.send_public_chat(msg)
	chat_input.text = \"\"

func _on_input_submitted(_text):
	_on_send_pressed()

func _on_message(data):
	_messages.append(data)
	_render_message(data.get(\"username\", \"Unknown\"), data.get(\"message\", \"\"))

func _on_history(data):
	chat_log.clear()
	_messages = data.get(\"messages\", [])
	for m in _messages:
		_render_message(m.get(\"username\", \"Unknown\"), m.get(\"message\", \"\"))

func _render_message(username, message):
	var color = \"#8888cc\"
	if auth and auth.current_user and username == auth.current_user[\"username\"]:
		color = \"#d4a820\"
	chat_log.append_text(\"[color=\" + color + \"][b]\" + username + \":[/b][/color] \" + message + \"\\n\")
"

