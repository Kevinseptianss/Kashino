anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 4
alignment = 1

[node name="HomeBtn" type="Button" parent="ContentRoot/BottomNav/HBoxContainer"]
