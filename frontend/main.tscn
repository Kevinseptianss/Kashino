[sub_resource type="GDScript" id="GDScript_main"]
script/source = "extends Control

@onready var profile_section = $ContentRoot/Header/MarginContainer/HBoxContainer/ProfileSection
@onready var balance_section = $ContentRoot/Header/MarginContainer/HBoxContainer/BalanceSection
@onready var login_btn = $ContentRoot/Header/MarginContainer/HBoxContainer/LoginBtn
@onready var balance_label = $ContentRoot/Header/MarginContainer/HBoxContainer/BalanceSection/MarginContainer/Label
@onready var username_label = $ContentRoot/Header/MarginContainer/HBoxContainer/ProfileSection/UserInfo/Username

func _ready():
	# This sets the window to 1280x720 immediately on launch
	DisplayServer.window_set_size(Vector2i(1280, 720))
	
	# Optional: Center it on the screen
	var screen_size = DisplayServer.screen_get_size()
	var window_size = DisplayServer.window_get_size()
	DisplayServer.window_set_position(screen_size / 2 - window_size / 2)

	print(\"Main scene ready started\")
	
	# Initial UI state (Logged Out)
	_on_logout()
	
	# Connect to Auth Service
	if has_node(\"/root/AuthService\"):
		var auth = get_node(\"/root/AuthService\")
		auth.login_success.connect(_on_login_success)
		auth.balance_updated.connect(update_balance)
	
	# Connect local signals
	$ContentRoot/BottomNav/HBoxContainer/HomeBtn.pressed.connect(_on_home_pressed)
	$ContentRoot/BottomNav/HBoxContainer/GamesBtn.pressed.connect(_on_games_pressed)
	$ContentRoot/BottomNav/HBoxContainer/WalletBtn.pressed.connect(_on_wallet_pressed)
	$ContentRoot/BottomNav/HBoxContainer/MenuBtn.pressed.connect(_on_menu_pressed)
	login_btn.pressed.connect(_on_login_btn_pressed)
	
	print(\"Main scene ready finished\")

func _on_login_btn_pressed():
	print(\"Opening Login Screen\")
	var login_screen = preload(\"res://LoginScreen.tscn\").instantiate()
	add_child(login_screen)

func _on_login_success(user_data):
	profile_section.show()
	balance_section.show()
	login_btn.hide()
	update_username(user_data[\"username\"])
	update_balance(user_data[\"balance\"])

func _on_logout():
	profile_section.hide()
	balance_section.hide()
	login_btn.show()

func update_balance(amount: int):
	var formatted = \"\"
	var s = str(int(amount))
	var count = 0
	for i in range(s.length() - 1, -1, -1):
		formatted = s[i] + formatted
		count += 1
		if count == 3 and i > 0:
			formatted = \",\" + formatted
			count = 0
	balance_label.text = formatted

func update_username(new_name: String):
	username_label.text = new_name

func _on_home_pressed(): print(\"Home pressed\")
func _on_games_pressed(): print(\"Games pressed\")
func _on_wallet_pressed(): print(\"Wallet pressed\")
func _on_menu_pressed(): print(\"Menu pressed\")
"

