theme_override_styles/normal = SubResource("StyleBoxFlat_play_btn")
text = "PLAY NOW"

; ---- POKER CARD ----
[node name="PokerPanel" type="PanelContainer" parent="ContentRoot/ScrollArea/Content/GamesSection/Padding/CardContainer"]
custom_minimum_size = Vector2(0, 180)
layout_mode = 2
size_flags_horizontal = 3
theme_override_styles/panel = SubResource("StyleBoxFlat_poker_card")
pivot_offset = Vector2(340, 90)

[node name="Margin" type="MarginContainer" parent="ContentRoot/ScrollArea/Content/GamesSection/Padding/CardContainer/PokerPanel"]
layout_mode = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_right = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_bottom = 20

[node name="HBox" type="HBoxContainer" parent="ContentRoot/ScrollArea/Content/GamesSection/Padding/CardContainer/PokerPanel/Margin"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="Icon" type="TextureRect" parent="ContentRoot/ScrollArea/Content/GamesSection/Padding/CardContainer/PokerPanel/Margin/HBox"]
custom_minimum_size = Vector2(100, 100)
layout_mode = 2
size_flags_vertical = 4
texture = ExtResource("3")
expand_mode = 1
stretch_mode = 5

[node name="Info" type="VBoxContainer" parent="ContentRoot/ScrollArea/Content/GamesSection/Padding/CardContainer/PokerPanel/Margin/HBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6
alignment = 1

[node name="Title" type="Label" parent="ContentRoot/ScrollArea/Content/GamesSection/Padding/CardContainer/PokerPanel/Margin/HBox/Info"]
layout_mode = 2
text = "TEXAS HOLD'EM"
theme_override_colors/font_color = Color(0.7, 0.82, 0.98, 1)
theme_override_font_sizes/font_size = 22

[node name="Desc" type="Label" parent="ContentRoot/ScrollArea/Content/GamesSection/Padding/CardContainer/PokerPanel/Margin/HBox/Info"]
layout_mode = 2
text = "Play poker with friends"
theme_override_colors/font_color = Color(0.45, 0.52, 0.62, 0.7)
theme_override_font_sizes/font_size = 12

[node name="PlayBtn" type="Button" parent="ContentRoot/ScrollArea/Content/GamesSection/Padding/CardContainer/PokerPanel/Margin/HBox/Info"]
custom_minimum_size = Vector2(120, 36)
layout_mode = 2
size_flags_horizontal = 0
theme_override_colors/font_color = Color(0.95, 0.95, 1.0, 1)
theme_override_font_sizes/font_size = 13
theme_override_styles/normal = SubResource("StyleBoxFlat_play_btn_blue")
text = "PLAY NOW"

; ---- BOTTOM SPACER ----
[node name="BottomSpacer" type="Control" parent="ContentRoot/ScrollArea/Content"]
custom_minimum_size = Vector2(0, 24)
layout_mode = 2

; ==================== BOTTOM NAVIGATION ====================
[node name="BottomNav" type="Panel" parent="ContentRoot"]
