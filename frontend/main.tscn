[sub_resource type="GDScript" id="GDScript_main"]
script/source = "extends Control

@onready var profile_section = $ContentRoot/Header/MarginContainer/HBoxContainer/ProfileSection
@onready var balance_section = $ContentRoot/Header/MarginContainer/HBoxContainer/BalanceSection
@onready var login_btn = $ContentRoot/Header/MarginContainer/HBoxContainer/LoginBtn
@onready var balance_label = $ContentRoot/Header/MarginContainer/HBoxContainer/BalanceSection/MarginContainer/Label
@onready var username_label = $ContentRoot/Header/MarginContainer/HBoxContainer/ProfileSection/UserInfo/Username
@onready var tier_label = $ContentRoot/Header/MarginContainer/HBoxContainer/ProfileSection/UserInfo/TierLabel
@onready var avatar_ring = $ContentRoot/Header/MarginContainer/HBoxContainer/ProfileSection/AvatarContainer/AvatarRing
@onready var avatar_initial = $ContentRoot/Header/MarginContainer/HBoxContainer/ProfileSection/AvatarContainer/AvatarRing/InitialLabel
@onready var status_dot = $ContentRoot/Header/MarginContainer/HBoxContainer/StatusSection/Dot
@onready var status_text = $ContentRoot/Header/MarginContainer/HBoxContainer/StatusSection/Text

# Animation references
@onready var title_label = $ContentRoot/ScrollArea/Content/HeroSection/KashinoTitle
@onready var slot_card = $ContentRoot/ScrollArea/Content/GamesSection/Padding/CardContainer/SlotPanel
@onready var poker_card = $ContentRoot/ScrollArea/Content/GamesSection/Padding/CardContainer/PokerPanel
@onready var particles = $Particles

var time_elapsed: float = 0.0

const TIER_COLORS = {
	\"Wood\": Color(0.55, 0.41, 0.08, 1),
	\"Bronze\": Color(0.8, 0.5, 0.2, 1),
	\"Silver\": Color(0.75, 0.75, 0.75, 1),
	\"Gold\": Color(1, 0.84, 0, 1),
	\"Fire\": Color(1, 0.27, 0, 1),
	\"Diamond\": Color(0, 1, 1, 1)
}

func _ready():
	var auth = get_node_or_null(\"/root/AuthService\")
	var window_size = Vector2i(720, 1280)
	
	if auth and auth.is_side_by_side:
		var screen_size = DisplayServer.screen_get_size()
		var scale_factor = 1.0
		var total_width_needed = window_size.x * auth.instance_count
		
		if total_width_needed > screen_size.x:
			scale_factor = float(screen_size.x) / float(total_width_needed)
			window_size = Vector2i(int(window_size.x * scale_factor), int(window_size.y * scale_factor))
		
		DisplayServer.window_set_size(window_size)
		
		var start_x = (screen_size.x - (window_size.x * auth.instance_count)) / 2
		var pos_x = start_x + (window_size.x * auth.instance_index)
		var pos_y = (screen_size.y - window_size.y) / 2
		DisplayServer.window_set_position(Vector2i(pos_x, pos_y))
	else:
		DisplayServer.window_set_size(window_size)
		var screen_size = DisplayServer.screen_get_size()
		DisplayServer.window_set_position((screen_size - window_size) / 2)

	_on_logout()
	
	if has_node(\"/root/AuthService\"):
		auth = get_node(\"/root/AuthService\")
		auth.login_success.connect(_on_login_success)
		auth.balance_updated.connect(update_balance)
		auth.connection_status_changed.connect(_on_connection_status_changed)
		auth.tier_updated.connect(_on_tier_updated)
		_on_connection_status_changed(auth.ws_connected)
		auth.auto_login()
	
	login_btn.pressed.connect(_on_login_btn_pressed)
	
	%WalletBtn.pressed.connect(_on_wallet_pressed)
	%ChatBtn.pressed.connect(_on_chat_btn_pressed)
	%MenuBtn.pressed.connect(_on_menu_pressed)
	
	# Entrance animations
	_play_entrance_animations()

func _play_entrance_animations():
	title_label.modulate = Color(1, 1, 1, 0)
	slot_card.modulate = Color(1, 1, 1, 0)
	poker_card.modulate = Color(1, 1, 1, 0)
	
	var tween = create_tween().set_parallel(true)
	
	tween.tween_property(title_label, \"modulate\", Color(1, 1, 1, 1), 0.8).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_CUBIC)
	tween.tween_property(title_label, \"scale\", Vector2(1, 1), 0.8).from(Vector2(0.7, 0.7)).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_BACK)
	
	tween.tween_property(slot_card, \"modulate\", Color(1, 1, 1, 1), 0.5).set_delay(0.4).set_ease(Tween.EASE_OUT)
	tween.tween_property(poker_card, \"modulate\", Color(1, 1, 1, 1), 0.5).set_delay(0.55).set_ease(Tween.EASE_OUT)
	
	await tween.finished

func _process(delta):
	time_elapsed += delta
	
	# Title golden shimmer
	if title_label:
		var shimmer = (sin(time_elapsed * 1.8) + 1.0) / 2.0
		var r = lerp(0.82, 1.0, shimmer)
		var g = lerp(0.62, 0.82, shimmer)
		var b = lerp(0.05, 0.18, shimmer)
		title_label.add_theme_color_override(\"font_color\", Color(r, g, b, 1.0))
	
	
	# Neon border pulse slot (gold)
	var si = 0.35 + 0.2 * sin(time_elapsed * 2.5)
	var ss = slot_card.get_theme_stylebox(\"panel\") as StyleBoxFlat
	if ss:
		ss.border_color = Color(0.85, 0.65, 0.1, si)
		ss.shadow_color = Color(0.85, 0.65, 0.1, si * 0.2)
	
	# Neon border pulse poker (blue)
	var pi = 0.35 + 0.2 * sin(time_elapsed * 2.5 + 1.2)
	var ps = poker_card.get_theme_stylebox(\"panel\") as StyleBoxFlat
	if ps:
		ps.border_color = Color(0.25, 0.55, 0.9, pi)
		ps.shadow_color = Color(0.25, 0.55, 0.9, pi * 0.2)

func _update_avatar(user_data):
	var tier = user_data.get(\"tier\", \"Wood\")
	var color = TIER_COLORS.get(tier, TIER_COLORS[\"Wood\"])
	avatar_ring.color = color
	
	var username = user_data.get(\"username\", \"?\")
	avatar_initial.text = username[0].to_upper()
	
	tier_label.text = tier.to_upper()
	tier_label.add_theme_color_override(\"font_color\", color)

func _on_tier_updated(data):
	if has_node(\"/root/AuthService\"):
		var auth = get_node(\"/root/AuthService\")
		if auth.current_user:
			_update_avatar(auth.current_user)

func _ensure_logged_in() -> bool:
	if has_node(\"/root/AuthService\"):
		var auth = get_node(\"/root/AuthService\")
		if not auth.current_user:
			_on_login_btn_pressed()
			return false
	return true

func _on_menu_pressed():
	if not _ensure_logged_in(): return
	var menu_page = preload(\"res://MenuPage.tscn\").instantiate()
	add_child(menu_page)

func _on_chat_btn_pressed():
	var chat_page = preload(\"res://PublicChat.tscn\").instantiate()
	add_child(chat_page)

func _on_wallet_pressed():
	if not _ensure_logged_in(): return
	var profile_page = preload(\"res://ProfilePage.tscn\").instantiate()
	add_child(profile_page)

func _on_slot_pressed():
	if not _ensure_logged_in(): return
	var slot_game = preload(\"res://SlotGame.tscn\").instantiate()
	add_child(slot_game)

func _on_poker_pressed():
	if not _ensure_logged_in(): return
	var room_list = preload(\"res://PokerRoomList.tscn\").instantiate()
	add_child(room_list)

func _on_login_btn_pressed():
	var login_screen = preload(\"res://LoginScreen.tscn\").instantiate()
	add_child(login_screen)

func _on_login_success(user_data):
	profile_section.show()
	balance_section.show()
	login_btn.hide()
	update_username(user_data[\"username\"])
	update_balance(user_data[\"balance\"])
	_update_avatar(user_data)

func _on_logout():
	profile_section.hide()
	balance_section.hide()
	login_btn.show()

func update_balance(amount):
	balance_label.text = \"C \" + str(int(amount))

func update_username(new_name: String):
	username_label.text = new_name

func _on_connection_status_changed(online):
	if online:
		status_dot.color = Color(0.2, 0.9, 0.3, 1)
		status_text.text = \"Online\"
		status_text.add_theme_color_override(\"font_color\", Color(0.2, 0.9, 0.3, 0.9))
	else:
		status_dot.color = Color(0.9, 0.2, 0.2, 1)
		status_text.text = \"Offline\"
		status_text.add_theme_color_override(\"font_color\", Color(0.9, 0.2, 0.2, 0.9))

func _on_profile_gui_input(event):
	if event is InputEventMouseButton and event.pressed and event.button_index == MOUSE_BUTTON_LEFT:
		if not _ensure_logged_in(): return
		var profile_page = preload(\"res://ProfilePage.tscn\").instantiate()
		add_child(profile_page)
"

